DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=job_scheduler
DB_CONNECTION_LIMIT=10

# How many jobs this worker process can run concurrently
WORKER_CONCURRENCY=5
# How often (ms) the worker polls each queue for new work
POLL_INTERVAL_MS=1500
# How often (ms) the worker reports a heartbeat
HEARTBEAT_INTERVAL_MS=5000
# Comma-separated queue names to poll. Leave empty to poll all queues.
WORKER_QUEUES=

# Optional bonus feature: AI-generated Dead Letter Queue failure summaries.
# Leave ANTHROPIC_API_KEY unset to disable — the worker runs fine without it.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
